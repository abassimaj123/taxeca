    <!-- Tax tooltips -->
    <string name="tooltip_gst_title">TPS — Taxe sur les produits et services</string>
    <string name="tooltip_gst_body">Taxe fédérale de 5 % applicable à la plupart des biens et services dans toutes les provinces et territoires canadiens.</string>
    <string name="tooltip_pst_title">TVP — Taxe de vente provinciale</string>
    <string name="tooltip_pst_body">Taxe provinciale variant selon la province (6–7 %). Non applicable en Alberta, dans les Territoires du Nord-Ouest, au Nunavut et au Yukon.</string>
    <string name="tooltip_qst_title">TVQ — Taxe de vente du Québec</string>
    <string name="tooltip_qst_body">Taxe provinciale québécoise de 9,975 %, calculée sur le montant de base avant taxes (non composée sur la TPS).</string>
    <string name="tooltip_rst_title">TDV — Taxe de vente au détail</string>
    <string name="tooltip_rst_body">Taxe provinciale de vente au détail du Manitoba de 7 %, appliquée sur le montant de base avant TPS.</string>
    <string name="tooltip_hst_title">TVH — Taxe de vente harmonisée</string>
    <string name="tooltip_hst_body" formatted="false">Une taxe unique combinant la part fédérale de la TPS (5 %) et la part provinciale en un seul taux. Applicable au N.-B. (15 %), T.-N.-L. (15 %), N.-É. (14 %), Ont. (13 %) et Î.-P.-É. (15 %). La Nouvelle-Écosse a réduit son taux à 14 % le 1er avril 2025 (baisse depuis 15 %).</string>
    <string name="premium_gate_title">Historique verrouillé</string>
    <string name="premium_gate_message">Regardez une pub pour 1 heure d\'accès, ou obtenez Premium pour un historique illimité.</string>

