    <!-- Tax tooltips -->
    <string name="tooltip_gst_title">GST — Goods &amp; Services Tax</string>
    <string name="tooltip_gst_body">Federal tax of 5% applied on most goods and services across all Canadian provinces and territories.</string>
    <string name="tooltip_pst_title">PST — Provincial Sales Tax</string>
    <string name="tooltip_pst_body">Provincial tax that varies by province (6–7%). Not applied in Alberta, Northwest Territories, Nunavut, or Yukon.</string>
    <string name="tooltip_qst_title">QST — Quebec Sales Tax</string>
    <string name="tooltip_qst_body">Quebec\'s provincial tax of 9.975%, calculated on the pre-tax base amount (not compounded on GST).</string>
    <string name="tooltip_rst_title">RST — Retail Sales Tax</string>
    <string name="tooltip_rst_body">Manitoba\'s provincial retail sales tax of 7%, applied on the base amount before GST.</string>
    <string name="tooltip_hst_title">HST — Harmonized Sales Tax</string>
    <string name="tooltip_hst_body" formatted="false">A single tax that combines the federal GST (5%) and the provincial portion into one rate. Applied in NB (15%), NL (15%), NS (14%), ON (13%), and PE (15%). Nova Scotia reduced its rate to 14% effective April 1, 2025 (down from 15%).</string>
